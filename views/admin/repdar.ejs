                        <td><%= row.Appointments %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>-->
    <% } else if (locals.results) { %>
        <p><strong>No data found</strong> for those specific dates or department.</p>
    <% } %>
</body>
</html>