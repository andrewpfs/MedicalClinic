<!--

SELECT E.EmployeeID, E.FirstName, E.LastName, D.DepartmentName, COUNT(A.AppointmentID) AS Appointments 
FROM department AS D, appointment AS A, employee as E 
WHERE A.DoctorID = E.EmployeeID AND E.DepartmentID = D.DepartmentID AND A.AppointmentDate >= ? AND A.AppointmentDate <= ? AND D.DepartmentName = ? 
GROUP BY E.EmployeeID 
ORDER BY Appointments DESC`;
 

-->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Department Appointment Report</title>
    <style>
        body { font-family: sans-serif; margin: 40px; }
        table { border-collapse: collapse; width: 100%; margin-top: 20px; }
        th, td { border: 1px solid #ccc; padding: 12px; text-align: left; }
        th { background-color: #f4f4f4; }
        .form-section { background: #f9f9f9; padding: 20px; border-radius: 8px; }
        input, button { padding: 8px; margin: 5px; }
        button { background-color: #2e4d2e; color: white; border: none; cursor: pointer; }
    </style>
</head>
<button><a href="/admin/home">Home</a></button>
<body>

    <div class="form-section">
        <h1>Department Appointment Report</h1>
        <p>Insert Department, Minimum and Maximum Range for the Dates</p>
        
        <form action="/admin/pulldar" method="post">
            <label>Department: 
                <input type="text" name="DepartmentName" placeholder="e.g. General" required>
            </label>
            <label>Minimum: 
                <input type="date" name="min" required>
            </label>
            <label>Maximum: 
                <input type="date" name="max" required>
            </label>
            <button type="submit">Generate Report</button>
        </form>
        <hr>
        <% if (locals.results && results.length > 0) { %>
            <h2>Department Results</h2>
            <table border="1" cellpadding="10" style="border-collapse: collapse; width: 100%;">
                <thead>
                    <tr style="background-color: #f2f2f2;">
                        <th>Employee ID</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Total Appointments</th>
                    </tr>
                </thead>
                <tbody>
                    <% results.forEach(row => { %>
                        <tr>
                            <td><%= row.EmployeeID %></td>
                            <td><%= row.FirstName %> <%= row.LastName %></td>
                            <td><%= row.DepartmentName %></td>
                            <td><%= row.Appointments %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else if (locals.results) { %>
            <p>No appointments found for those dates.</p>
        <% } %>
    </div>
    <hr>
    <br>
    <body>
    <% if (results.length > 0) { %>
        
        The Doctor with the most appointments in <%= results[0].DepartmentName %> is <%= topE %> with <% topA %> Appointments
        
    <% } %>
    <% if (zeros.length > 0) { %>
        , while 
        <% if (zeros.length == 1) {%>
            <%= zeros[0].FirstName %> <%= zeros[0].LastName %> has 
        <% } %>
        <% else if (zeros.length == 2) { %>
            <%= zeros[0].FirstName %> <%= zeros[0].LastName %> and <%= zeros[1].FirstName %> <%= zeros[1].LastName %> have 
        <% } %>
        <% else { %>
            <% for (let i=0; i<zeros.length-2;i++) { %>
                <%= zeros[i].FirstName %> <%= zeros[i].LastName %>, 
            <% } %>
            and <%= zeros[zeros.length-1].FirstName %> <%= zeros[zeros.length-1].LastName %> have 
        <% } %>
        0 Appointments.
    <% }else if (results.length > 1) { %>
        <% const low = results.length - 1; %>
        , while the Doctor with the lowest appointments is <%= results[low].FirstName %> <%= results[low].LastName %> with <%= results[low].Appointments %> Appointments.
    <% } %>

    </body>
