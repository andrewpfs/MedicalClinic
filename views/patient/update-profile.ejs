<!DOCTYPE html>
<html>
<head>
    <title>Update Profile</title>
    <style>
        body { font-family: sans-serif; margin: 40px; }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input { padding: 8px; width: 300px; }
        button { padding: 10px 20px; background-color: #007bff; color: white; border: none; cursor: pointer; }
    </style>
</head>
<body>
    <h2>Update Your Contact Information</h2>
    
    <form action="/patient/update-profile" method="POST">
        <div class="form-group">
            <label>Phone Number:</label>
            <input type="text" name="phone" value="<%= patient.PhoneNumber %>" placeholder="e.g. 555-0123">
        </div>
        
        <div class="form-group">
            <label>Email Address:</label>
            <input type="email" name="email" value="<%= patient.Email %>" required>
        </div>
        
        <button type="submit">Save Changes</button>
    </form>
    
    <br>
    <a href="/patient/profile">Cancel and Go Back</a>
</body>
</html>