<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Patient Portal</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f7f6; margin: 0; padding: 0; color: #333; }
        .container { max-width: 900px; margin: 0 auto; padding: 20px; }
        
        .welcome-header { text-align: center; margin-bottom: 30px; padding: 20px 0; }
        .welcome-header h1 { font-size: 2.2em; font-weight: 300; margin: 0; }

        .action-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 40px; }
        .action-card { background: white; height: 130px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); text-decoration: none; color: #333; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 1px solid #ddd; transition: background 0.2s; }
        .action-card:hover { background-color: #f9f9f9; border-color: #bbb; }
        
        .icon { font-size: 2em; margin-bottom: 10px; filter: grayscale(100%); opacity: 0.7; }
        .label { font-size: 0.85em; text-align: center; font-weight: bold; }

        .info-section { background: white; border: 1px solid #ddd; border-radius: 5px; overflow: hidden; }
        .info-row { display: flex; border-bottom: 1px solid #eee; }
        .info-row:last-child { border-bottom: none; }
        .info-label { width: 220px; background-color: #f9f9f9; padding: 12px; font-weight: bold; border-right: 1px solid #eee; font-size: 0.9em; }
        .info-value { padding: 12px; flex: 1; font-size: 0.9em; }

        .logout-link { display: block; text-align: center; margin-top: 30px; color: #888; text-decoration: none; font-size: 0.85em; }
    </style>
</head>
<body>

<div class="container">

    <div class="welcome-header">
        <h1>Welcome, <%= patient.FName %>!</h1>
    </div>

    <div class="action-grid">
        <a href="/patient/booking" class="action-card">
            <span class="icon">📅</span>
            <span class="label">Schedule an Appointment</span>
        </a>
        <a href="/patient/visits" class="action-card">
            <span class="icon">📄</span>
            <span class="label">Visit History</span>
        </a>
        <a href="/patient/payments" class="action-card">
            <span class="icon">💳</span>
            <span class="label">Make a Payment</span>
        </a>
        <a href="/patient/update-profile" class="action-card">
            <span class="icon">⚙️</span>
            <span class="label">Update Information</span>
        </a>
    </div>

    <div class="info-section">
        <div class="info-row">
            <div class="info-label">Medical Record Number</div>
            <div class="info-value"><%= patient.PatientID %></div>
        </div>
        <div class="info-row">
            <div class="info-label">Patient Name</div>
            <div class="info-value"><%= patient.FName %> <%= patient.LName %></div>
        </div>
        <div class="info-row">
            <div class="info-label">Email</div>
            <div class="info-value"><%= patient.Email %></div>
        </div>
        <div class="info-row">
            <div class="info-label">Contact Number</div>
            <div class="info-value"><%= patient.PhoneNumber %></div>
        </div>
        <div class="info-row">
            <div class="info-label">Address</div>
            <div class="info-value"><%= patient.Address || 'N/A' %></div>
        </div>
        <div class="info-row">
            <div class="info-label">Date of Birth</div>
            <div class="info-value">
                <%= patient.DOB ? new Date(patient.DOB).toLocaleDateString() : 'N/A' %>
            </div>
        </div>
    </div>

    <a href="/patient/logout" class="logout-link">Sign Out</a>

</div>

</body>
</html>